name: flutter_application_1rentalf
description: A Flutter app for BASERENT equipment rental
publish_to: "none" # Remove this line if you want to publish to pub.dev

version: 1.0.0+1

environment:
  sdk: ">=3.0.0 <4.0.0"

dependencies:
  flutter:
    sdk: flutter

  cupertino_icons: ^1.0.6
  firebase_core: ^2.15.0
  firebase_auth: ^4.9.0
  cloud_firestore: ^4.9.0
  firebase_storage: ^11.2.0
  flutter_stripe: ^9.1.0
  image_picker: ^0.8.7+5
  intl: ^0.18.1
  file_picker: ^6.1.5

http: ^1.1.0
provider: ^11.2.0

dev_dependencies:
  flutter_test:
    sdk: flutter
  flutter_lints: ^2.0.1

flutter:
  uses-material-design: true
